# ============================================================
# E4 BACKEND - Environment Variables
# Copy this file to .env and fill in the values
# Used by docker-compose to inject secrets into services
# ============================================================

# JWT - min 32 chars for HS256
JWT_SECRET=change-me-to-a-secure-random-secret-minimum-32-characters
JWT_EXPIRATION_MS=86400000

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Stripe - use sk_test_* keys for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com
