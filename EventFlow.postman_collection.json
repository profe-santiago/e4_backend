{
  "info": {
    "name": "EventFlow API",
    "description": "Colección completa de endpoints del sistema EventFlow. Importar en Postman y configurar las variables de colección antes de usar.\n\nFlujo básico:\n1. Ejecutar **Register** o **Login** → el token se guarda automáticamente\n2. Ejecutar los demás endpoints con el token guardado\n\nVariables de colección: baseUrl, token, refreshToken, userId, eventId, ticketTypeId, orderId, ticketId, notificationId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080" },
    { "key": "token",         "value": "" },
    { "key": "refreshToken",  "value": "" },
    { "key": "userId",        "value": "" },
    { "key": "eventId",       "value": "" },
    { "key": "ticketTypeId",  "value": "" },
    { "key": "orderId",       "value": "" },
    { "key": "ticketId",      "value": "" },
    { "key": "notificationId","value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const data = pm.response.json();",
                "if (data.token) {",
                "  pm.collectionVariables.set('token', data.token);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Buyer123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const data = pm.response.json();",
                "if (data.token) {",
                "  pm.collectionVariables.set('token', data.token);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@test.com\",\n  \"password\": \"Buyer123!\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const data = pm.response.json();",
                "if (data.token) {",
                "  pm.collectionVariables.set('token', data.token);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const data = pm.response.json();",
                "if (data.token) {",
                "  pm.collectionVariables.set('token', data.token);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },

    {
